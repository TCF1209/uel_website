# Auto-detect text files and normalize line endings to LF on commit.
# Each developer's working copy can still use whatever native line ending
# their editor produces; git stores LF and normalizes on add.
* text=auto eol=lf

# Explicit text files (belt and suspenders).
*.html  text eol=lf
*.css   text eol=lf
*.js    text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.svg   text eol=lf
*.txt   text eol=lf
*.xml   text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf

# Binary files — never touch these.
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.pdf   binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.eot   binary
*.zip   binary
