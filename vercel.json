{
  "rewrites": [
    { "source": "/zh", "destination": "/index.html" },
    { "source": "/zh/", "destination": "/index.html" },
    { "source": "/bm", "destination": "/index.html" },
    { "source": "/bm/", "destination": "/index.html" },
    { "source": "/zh/:path+", "destination": "/:path+" },
    { "source": "/bm/:path+", "destination": "/:path+" }
  ]
}
